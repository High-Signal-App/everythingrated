{
  "name": "@everythingrated/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate:local": "wrangler d1 migrations apply everythingrated-db --local --config=../../apps/web/wrangler.toml",
    "migrate:remote": "wrangler d1 migrations apply everythingrated-db --remote --config=../../apps/web/wrangler.toml",
    "studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260424.1",
    "drizzle-kit": "0.31.10",
    "typescript": "5.6.3",
    "wrangler": "4.85.0"
  }
}
