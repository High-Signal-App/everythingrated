# pnpm config — scoped hoisting so Blume's generated Astro project can resolve
# its dependencies from the repo root. Blume (a dev dependency) generates an
# Astro project under .blume/ whose astro.config.mjs imports `astro/config`,
# `@astrojs/*`, `@shikijs/*`, and `@tailwindcss/vite`. pnpm's strict node_modules
# does not hoist transitive deps, so these patterns make them resolvable without
# a blanket `shamefully-hoist=true` (which would flatten the whole workspace).
#
# This only affects what is *visible* at the top-level node_modules; it does not
# change the app's own dependency graph. The Next.js / Cloudflare app resolves
# its deps through its workspace node_modules as before.
public-hoist-pattern[]=astro
public-hoist-pattern[]=astro/*
public-hoist-pattern[]=@astrojs/*
public-hoist-pattern[]=@shikijs/*
public-hoist-pattern[]=@tailwindcss/vite
