{
  "name": "everythingrated",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "cf:build": "pnpm --filter web cf:build",
    "deploy": "pnpm --filter web run deploy",
    "start": "pnpm --filter web start",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @everythingrated/db generate",
    "db:migrate:local": "pnpm --filter @everythingrated/db migrate:local",
    "db:migrate:remote": "pnpm --filter @everythingrated/db migrate:remote",
    "db:studio": "pnpm --filter @everythingrated/db studio",
    "db:seed:local": "tsx scripts/seed-d1.ts --local",
    "db:seed:remote": "tsx scripts/seed-d1.ts --remote",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "docs:check": "bash scripts/validate-docs.sh",
    "docs:build": "blume build",
    "docs:dev": "blume dev",
    "docs:preview": "blume preview",
    "docs:validate": "blume validate",
    "docs:doctor": "blume doctor",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@vitest/coverage-v8": "^4.1.9",
    "astro": "7.1.1",
    "blume": "1.0.4",
    "husky": "9.1.7",
    "next": "16.2.4",
    "tsx": "4.21.0",
    "typescript": "5.6.3",
    "vitest": "4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@opentelemetry/api"
      ]
    }
  }
}
