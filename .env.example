# EverythingRated runs on Cloudflare Workers via @opennextjs/cloudflare.
# D1 binding is declared in apps/web/wrangler.toml — no DB env vars needed.

# ──────────── App ────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
MODERATION_TOKEN=

# ──────────── SaaS Maker ────────────
NEXT_PUBLIC_SAASMAKER_API_KEY=

# ──────────── PostHog (@saas-maker/posthog-client) ────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
